{
  "expo": {
    "name": "Umbler Talk",
    "slug": "umbler-talk-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "umblertalk",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C3CE1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.umbler.talk.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C3CE1"
      },
      "package": "com.umbler.talk.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#6C3CE1"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
