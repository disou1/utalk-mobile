<!doctype html>
<html lang="pt-br"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Umbler Talk Mobile Preview</title>
<style>
:root{--brand:#5B6EF5;--bg:#EEF1F7;--surface:#fff;--border:#DCE1EC;--text:#22304A;--muted:#8A94A6;--green:#63D4C8;--out:#E8F2DB;--note:#F6ECD0}
*{box-sizing:border-box;font-family:Inter,Arial,sans-serif}body{margin:0;background:#d9dde7;padding:24px;color:var(--text)}.phone{width:390px;max-width:100%;height:844px;background:var(--bg);border-radius:34px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.18);margin:auto;position:relative}.screen{display:none;height:100%;overflow:auto}.screen.active{display:block}.top{padding:18px 16px 10px;background:#fff;display:flex;justify-content:space-between;align-items:center}.logo{width:28px;height:28px;border-radius:14px;background:#fff;display:grid;place-items:center;color:var(--brand);font-weight:700}.icons{display:flex;gap:14px}.seg{display:flex;margin:12px 16px 8px;background:#DDE4F4;border-radius:18px;padding:4px}.seg button{flex:1;border:0;background:transparent;padding:10px;border-radius:14px;color:var(--muted)}.seg button.active{background:var(--brand);color:#fff}.search{margin:0 16px 8px}.search input,.composer input{width:100%;border:1px solid var(--border);border-radius:14px;padding:14px;background:#fff}.list{padding:0 16px 100px}.item{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid var(--border);cursor:pointer}.avatar{width:52px;height:52px;border-radius:26px;background:#dce4ff;display:grid;place-items:center;color:var(--brand);font-weight:700}.main{flex:1}.row{display:flex;justify-content:space-between;align-items:center}.name{font-weight:700}.time,.sub{color:var(--muted);font-size:12px}.preview{display:flex;gap:6px;align-items:center;margin:6px 0;color:var(--muted)}.tags{display:flex;gap:6px;align-items:center}.tag{background:var(--green);border-radius:99px;padding:4px 10px;font-size:11px}.badge{min-width:24px;height:24px;border-radius:12px;background:var(--brand);color:#fff;display:grid;place-items:center;padding:0 8px;font-size:12px}.fab{position:absolute;right:18px;bottom:86px;width:56px;height:56px;border-radius:28px;background:var(--brand);display:grid;place-items:center;color:#fff;font-size:30px;cursor:pointer}.tabbar{position:absolute;left:0;right:0;bottom:0;background:#fff;border-top:1px solid var(--border);display:flex}.tabbar button{flex:1;background:none;border:0;padding:12px;color:var(--muted)}.tabbar button.active{color:var(--brand);font-weight:700}.chatHeader{padding:10px 12px;background:#fff;display:flex;align-items:center;gap:10px}.bubbleWrap{display:flex;gap:8px;margin-bottom:12px;align-items:flex-end}.bubbleWrap.me{justify-content:flex-end}.bubble{max-width:78%;padding:14px 16px;border-radius:18px;background:#fff;box-shadow:0 4px 12px rgba(47,72,123,.08)}.me .bubble{background:var(--out)}.system{margin:0 auto 12px;background:#FEF7DA;border-radius:16px;padding:10px 12px;max-width:82%;font-size:13px}.bot{width:32px;height:32px;border-radius:16px;background:#DDE7FF;display:grid;place-items:center}.msgs{padding:12px 10px 168px}.composerArea{position:absolute;left:0;right:0;bottom:0;background:#fff;border-top:1px solid var(--border)}.composerArea.note{background:var(--note)}.hint{color:#A7B0C0;font-size:13px;padding:10px 16px 6px}.composer{display:flex;gap:8px;align-items:center;padding:0 12px}.plus,.mic{width:42px;height:42px;border-radius:21px;border:0}.plus{background:transparent}.mic{background:var(--brand);color:#fff}.switch{display:flex;justify-content:center;gap:8px;padding:10px}.switch button{border:0;background:none;padding:10px 14px;border-radius:18px;color:var(--muted);display:flex;gap:6px}.switch button.activeMsg{background:var(--brand);color:#fff}.switch button.activeNote{background:#C9A500;color:#fff}.notifHead{padding:18px;text-align:center;background:#fff;font-weight:700}.notiftabs{display:flex;gap:14px;padding:0 16px 12px;border-bottom:1px solid var(--border);background:#fff}.notiftabs button{border:0;background:none;padding:12px 0;border-bottom:2px solid transparent;color:var(--muted)}.notiftabs button.active{color:var(--brand);border-color:var(--brand)}.notiflist{padding:16px}.card{background:#fff;border:1px solid var(--border);border-radius:20px;padding:16px;margin-bottom:12px}.empty{padding-top:110px;text-align:center;color:#666}.sheet{position:absolute;left:0;right:0;bottom:0;background:#fff;border-radius:22px 22px 0 0;padding:10px 22px 28px;display:none}.sheet.open{display:block}.handle{width:44px;height:4px;background:#C9CDD6;border-radius:3px;margin:0 auto 14px}.menuItem{padding:12px 0;border:0;background:none;width:100%;text-align:left;color:var(--text)}.overlay{position:absolute;inset:0;background:rgba(33,38,48,.38);display:none}.overlay.open{display:block}.section{padding:18px}.pill{display:inline-block;padding:6px 10px;background:var(--green);border-radius:99px;margin-right:8px;margin-bottom:8px;font-size:12px}.rowCard{background:#fff;border:1px solid var(--border);border-radius:20px;padding:16px;margin-bottom:12px;cursor:pointer}
</style></head>
<body><div class="phone">
<div id="inbox" class="screen active">
  <div class="top"><div class="logo">U</div><div class="icons">⌕ ⌯ 🔔</div></div>
  <div class="seg"><button class="active">Entrada</button><button>Esperando</button><button>Finalizados</button></div>
  <div class="search"><input placeholder="Buscar contato, etiqueta ou mensagem"></div>
  <div class="list">
    <div class="item" onclick="openChat()"><div class="avatar">RY</div><div class="main"><div class="row"><div class="name">Ryan</div><div class="time">08:25</div></div><div class="preview">🟢 teste</div><div class="row"><div class="tags"><span class="tag">Talk2</span><span class="tag" style="background:#ECECF2">teste Sa...</span></div><div class="badge">1</div></div></div></div>
    <div class="item"><div class="avatar">DI</div><div class="main"><div class="row"><div class="name">Disou</div><div class="time">15:04</div></div><div class="preview">🟢 Olá tudo bem? O q...</div><div class="row"><div class="tags"><span class="tag" style="background:#ECECF2">Geral</span></div><div class="badge">17</div></div></div></div>
  </div>
  <div class="fab" onclick="openChat()">+</div>
</div>
<div id="chat" class="screen">
  <div class="chatHeader"><button onclick="show('inbox')" style="border:0;background:none">‹</button><div class="avatar" style="width:40px;height:40px">RY</div><div style="flex:1" onclick="show('contact')"><div class="name">Ryan</div><div><span class="tag">Talk2</span></div></div><button onclick="menu(true)" style="border:0;background:none">⋮</button></div>
  <div class="msgs" id="msgs">
    <div class="system">Chatbot “Teste Template Samuel-&gt;Início” iniciado manualmente.</div>
    <div class="bubbleWrap me"><div class="bubble">Olá, tudo bem?<br><br>Assim que possível, poderia me chamar?<div class="time">08:24 ✓✓</div></div></div>
    <div class="bubbleWrap"><div class="bubble">Claro!<div class="time">08:25</div></div><div class="bot">🤖</div></div>
    <div class="bubbleWrap me"><div class="bubble">teste<div class="time">08:25 ✓</div></div></div>
    <div class="bubbleWrap me"><div class="bubble">teste<div class="time">08:25 ✓✓</div></div></div>
  </div>
  <div class="composerArea" id="composerArea"><div class="hint" id="hint">Digite sua mensagem ou arraste um arquivo...</div><div class="composer"><button class="plus">＋</button><input id="msgInput" placeholder="Digite sua mensagem..."><button class="mic" onclick="sendMsg()">➤</button></div><div class="switch"><button id="tabMsg" class="activeMsg" onclick="setMode('message')">💬 Mensagem</button><button id="tabNote" onclick="setMode('note')">🗒 Notas</button></div></div>
  <div id="overlay" class="overlay" onclick="menu(false)"></div>
  <div id="sheet" class="sheet"><div class="handle"></div><button class="menuItem" onclick="show('contact');menu(false)">Detalhes do contato</button><button class="menuItem" onclick="show('transfer');menu(false)">Transferir conversa</button><button class="menuItem" onclick="addTag();menu(false)">Registrar etiqueta</button><button class="menuItem" onclick="menu(false)">Ocultar essa janela</button></div>
</div>
<div id="notifications" class="screen">
  <div class="notifHead">Notificações</div>
  <div class="notiftabs"><button class="active">Menções</button><button>Atividades</button><button>Novidades</button></div>
  <div class="notiflist" id="notiflist"><div class="card" onclick="openChat()"><strong>Nova mensagem</strong><div>Consegue me chamar agora?</div><div class="sub">agora</div></div></div>
</div>
<div id="contact" class="screen"><div class="section"><button onclick="openChat()" style="border:0;background:none;color:var(--brand)">Voltar</button><div style="text-align:center;padding:16px 0"><div class="avatar" style="width:80px;height:80px;margin:0 auto 12px">RY</div><div class="name" style="font-size:22px">Ryan</div><div class="sub">+55 31 8756–5581</div><div class="sub">Talk2</div></div><div class="rowCard"><strong>Etiquetas</strong><div style="margin-top:12px"><span class="pill">Talk2</span><span class="pill">teste Sa...</span></div></div><div class="rowCard"><strong>Notas e contexto</strong><div class="sub" style="margin-top:10px">Contato recorrente do fluxo de teste. Prefere ser chamado rapidamente quando o setor ficar disponível.</div></div><div class="rowCard" onclick="show('transfer')"><strong>Transferir conversa</strong></div></div></div>
<div id="transfer" class="screen"><div class="section"><button onclick="openChat()" style="border:0;background:none;color:var(--brand)">Voltar</button><h2>Transferir conversa</h2><div class="sub">Escolha outro membro ou setor.</div><div class="rowCard" onclick="alert('Transferido para Fernanda Costa')"><strong>Fernanda Costa</strong><div class="sub">Membro</div></div><div class="rowCard" onclick="alert('Transferido para Comercial')"><strong>Comercial</strong><div class="sub">Setor</div></div></div></div>
<div class="tabbar"><button class="active" onclick="show('inbox')">Inbox</button><button onclick="show('notifications')">Notificações</button><button onclick="show('contact')">Ajustes</button></div>
</div>
<script>
let mode='message';
function show(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');}
function openChat(){show('chat')}
function menu(v){document.getElementById('sheet').classList.toggle('open',v);document.getElementById('overlay').classList.toggle('open',v)}
function setMode(m){mode=m;document.getElementById('composerArea').classList.toggle('note',m==='note');document.getElementById('hint').textContent=m==='note'?'Digite uma nota que só os atendentes do Umbler Talk poderão ver...':'Digite sua mensagem ou arraste um arquivo...';document.getElementById('tabMsg').className=m==='message'?'activeMsg':'';document.getElementById('tabNote').className=m==='note'?'activeNote':'';document.getElementById('msgInput').placeholder=m==='note'?'Digite uma nota...':'Digite sua mensagem...';}
function sendMsg(){const i=document.getElementById('msgInput');if(!i.value.trim())return;const wrap=document.createElement('div');wrap.className='bubbleWrap me';wrap.innerHTML=`<div class="bubble" style="background:${mode==='note'?'var(--note)':'var(--out)'}">${i.value}<div class="time">agora ✓✓</div></div>`;document.getElementById('msgs').appendChild(wrap);i.value='';document.getElementById('msgs').scrollTop=999999;}
function addTag(){alert('Etiqueta registrada com sucesso')}
setInterval(()=>{const texts=['Consegue me chamar agora?','Tem atualização do meu atendimento?','Enviei a imagem agora há pouco.'];const t=texts[Math.floor(Math.random()*texts.length)];const card=document.createElement('div');card.className='card';card.innerHTML=`<strong>Nova mensagem</strong><div>${t}</div><div class="sub">agora</div>`;card.onclick=openChat;document.getElementById('notiflist').prepend(card);},15000)
</script></body></html>
